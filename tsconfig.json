{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "*"
      ]
    },
    "types": [
      "expo-router"
    ],
    "jsx": "react-native",
    "esModuleInterop": true,
    "lib": [
      "ESNext",
      "DOM"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "lucide.d.ts",
    ".expo/types/**/*.d.ts",
    "nativewind-env.d.ts"
  ]
}
